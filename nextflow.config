/*
========================================================================================
    Nextflow Configuration — Rare Variant GNN Pipeline
========================================================================================
*/

// ─── Manifest ─────────────────────────────────────────────────────────────────
manifest {
    name            = 'rare-variant-gnn'
    author          = 'GNN-RareVariant Pipeline'
    description     = 'GNN-based rare variant pathogenicity prediction'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}

// ─── Default Parameters (ensures no param is ever null) ───────────────────────
params {
    genome_build   = 'GRCh38'
    af_threshold   = 0.001
    graph_k_hops   = 2
    gnn_epochs     = 100
    gnn_lr         = 0.001
    gnn_hidden     = 128
    gnn_layers     = 3
    batch_size     = 64
    train_split    = 0.7
    val_split      = 0.15
    test_split     = 0.15
    seed           = 42
    publish_all    = false
    outdir         = 'results'
    mode           = 'full'
    skip_training  = false
    input_vcf      = null
    input_variants = null
    pretrained_model = null
    known_variants = "${projectDir}/data/example/clinvar_variants.tsv"
    ppi_network    = "${projectDir}/data/example/string_ppi.tsv"
    gene_annot     = "${projectDir}/data/example/gene_annotations.tsv"
    conservation   = "${projectDir}/data/example/conservation_scores.tsv"
    model_dir      = "${params.outdir}/models"
    help           = false
}

// ─── Process Settings ─────────────────────────────────────────────────────────
process {
    // Baseline fallback
    cpus   = 1
    memory = '2 GB'
    time   = '1h'

    // Retry with scaled memory on OOM
    errorStrategy = {
        task.exitStatus in [143, 137, 104, 134, 139]
            ? 'retry'
            : 'terminate'
    }
    maxRetries = 2

    // ── Per-process resources (memory scales ×attempt on retry) ─────────────
    withName: 'PARSE_VCF' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
        time   = '30m'
    }
    withName: 'FILTER_VARIANTS' {
        cpus   = 1
        memory = { 1.GB * task.attempt }
        time   = '15m'
    }
    withName: 'ANNOTATE_VARIANTS' {
        cpus   = 2
        memory = { 6.GB * task.attempt }
        time   = '4h'
    }
    withName: 'MERGE_LABELS' {
        cpus   = 1
        memory = { 1.GB * task.attempt }
        time   = '15m'
    }
    withName: 'SPLIT_DATASET' {
        cpus   = 1
        memory = { 1.GB * task.attempt }
        time   = '15m'
    }
    withName: 'EXTRACT_SEQUENCE_FEATURES' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
        time   = '30m'
    }
    withName: 'EXTRACT_CONSERVATION' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
        time   = '30m'
    }
    withName: 'EXTRACT_STRUCTURAL_FEATURES' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
        time   = '30m'
    }
    withName: 'EXTRACT_GENE_FEATURES' {
        cpus   = 1
        memory = { 1.GB * task.attempt }
        time   = '15m'
    }
    withName: 'COMBINE_FEATURES' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
        time   = '15m'
    }
    withName: 'BUILD_PROTEIN_GRAPH' {
        cpus   = 1
        memory = { 4.GB * task.attempt }
        time   = '30m'
    }
    withName: 'ASSIGN_NODE_FEATURES' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
        time   = '15m'
    }
    withName: 'SERIALIZE_GRAPH' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
        time   = '15m'
    }
    withName: 'TRAIN_GNN' {
        cpus   = 2
        memory = { 8.GB * task.attempt }
        time   = '8h'
    }
    withName: 'PREDICT_GNN' {
        cpus   = 2
        memory = { 4.GB * task.attempt }
        time   = '1h'
    }
    withName: 'EVALUATE_MODEL' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
        time   = '30m'
    }
    withName: 'HYPERPARAMETER_TUNE' {
        cpus   = 2
        memory = { 8.GB * task.attempt }
        time   = '12h'
    }
}

// ─── Profiles ─────────────────────────────────────────────────────────────────
profiles {

    // Local + conda (default, no containers needed)
    local {
        process.executor = 'local'
        conda.enabled    = true
        docker.enabled   = false
    }

    // Docker
    docker {
        process.executor     = 'local'
        docker.enabled       = true
        docker.userEmulation = true
        singularity.enabled  = false
    }

    // Singularity
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        process.executor       = 'local'
    }

    // SLURM
    slurm {
        process.executor       = 'slurm'
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        process.queue          = 'normal'
    }

    // AWS Batch
    awsbatch {
        process.executor  = 'awsbatch'
        process.queue     = 'default'
        aws.region        = 'us-east-1'
    }

    // Test — small memory caps, fast settings, no containers
    test {
        process.executor = 'local'
        conda.enabled    = true
        docker.enabled   = false

        params {
            input_vcf      = "${projectDir}/data/example/test_variants.vcf"
            known_variants = "${projectDir}/data/example/clinvar_variants.tsv"
            ppi_network    = "${projectDir}/data/example/string_ppi.tsv"
            gene_annot     = "${projectDir}/data/example/gene_annotations.tsv"
            conservation   = "${projectDir}/data/example/conservation_scores.tsv"
            gnn_epochs     = 5
            batch_size     = 16
            gnn_hidden     = 64
            gnn_layers     = 2
            outdir         = "${projectDir}/results/test"
            genome_build   = 'GRCh38'
        }

        process {
            withName: 'PARSE_VCF'                  { memory = '1 GB'; cpus = 1; time = '10m' }
            withName: 'FILTER_VARIANTS'             { memory = '1 GB'; cpus = 1; time = '10m' }
            withName: 'ANNOTATE_VARIANTS'           { memory = '2 GB'; cpus = 1; time = '30m' }
            withName: 'MERGE_LABELS'                { memory = '1 GB'; cpus = 1; time = '10m' }
            withName: 'SPLIT_DATASET'               { memory = '1 GB'; cpus = 1; time = '10m' }
            withName: 'EXTRACT_SEQUENCE_FEATURES'   { memory = '1 GB'; cpus = 1; time = '10m' }
            withName: 'EXTRACT_CONSERVATION'        { memory = '1 GB'; cpus = 1; time = '10m' }
            withName: 'EXTRACT_STRUCTURAL_FEATURES' { memory = '1 GB'; cpus = 1; time = '10m' }
            withName: 'EXTRACT_GENE_FEATURES'       { memory = '1 GB'; cpus = 1; time = '10m' }
            withName: 'COMBINE_FEATURES'            { memory = '1 GB'; cpus = 1; time = '10m' }
            withName: 'BUILD_PROTEIN_GRAPH'         { memory = '2 GB'; cpus = 1; time = '15m' }
            withName: 'ASSIGN_NODE_FEATURES'        { memory = '1 GB'; cpus = 1; time = '10m' }
            withName: 'SERIALIZE_GRAPH'             { memory = '1 GB'; cpus = 1; time = '10m' }
            withName: 'TRAIN_GNN'                   { memory = '4 GB'; cpus = 1; time = '30m' }
            withName: 'PREDICT_GNN'                 { memory = '2 GB'; cpus = 1; time = '15m' }
            withName: 'EVALUATE_MODEL'              { memory = '1 GB'; cpus = 1; time = '10m' }
        }
    }
}

// ─── Reports ──────────────────────────────────────────────────────────────────
timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/report.html"   }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/trace.txt"
           fields = 'task_id,hash,process,tag,status,exit,cpus,time,memory,attempt,duration,realtime,%cpu,%mem,rss,peak_rss' }
dag      { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/dag.svg"       }

// ─── Environment ──────────────────────────────────────────────────────────────
env {
    PYTHONNOUSERSITE = 1
    PYTHONPATH       = "${projectDir}/bin:${projectDir}/models"
}
